<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="id.asr.rppgvitals.presentation.javafx.dashboard.LiveMeasurementController"
      spacing="14.0" alignment="TOP_CENTER">
    <padding>
        <Insets top="20.0" right="20.0" bottom="16.0" left="20.0"/>
    </padding>

    <Label text="rPPG Vitals Monitor" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <HBox spacing="8.0" alignment="CENTER">
        <ComboBox fx:id="deviceSelector" promptText="Select a camera"/>
        <Button fx:id="refreshButton" text="Refresh" onAction="#onRefreshDevices"/>
        <Button fx:id="startStopButton" onAction="#onStartStop"/>
    </HBox>

    <Canvas fx:id="previewCanvas" width="360.0" height="270.0"/>

    <Label fx:id="heartRateLabel" style="-fx-font-size: 64px; -fx-font-weight: bold;"/>
    <Label fx:id="statusLabel" wrapText="true" style="-fx-font-size: 14px;"/>

    <Button fx:id="historyButton" text="View history" onAction="#onViewHistory"/>

    <Label text="Estimate only, not medical-grade"
           style="-fx-font-size: 11px; -fx-text-fill: #607D8B;">
        <VBox.margin>
            <Insets top="8.0"/>
        </VBox.margin>
    </Label>
</VBox>
