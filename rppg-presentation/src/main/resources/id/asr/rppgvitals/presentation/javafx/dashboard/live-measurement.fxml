<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="id.asr.rppgvitals.presentation.javafx.dashboard.LiveMeasurementController"
      spacing="14.0" alignment="TOP_CENTER">
    <padding>
        <Insets top="18.0" right="20.0" bottom="16.0" left="20.0"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <VBox spacing="1.0">
            <Label text="rPPG Vitals Monitor" styleClass="h1"/>
            <Label text="Live heart-rate estimate from your webcam" styleClass="subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="historyButton" text="History ▸" onAction="#onViewHistory"/>
    </HBox>

    <HBox spacing="8.0" alignment="CENTER" styleClass="card">
        <ComboBox fx:id="deviceSelector" promptText="Select a camera"/>
        <Button fx:id="refreshButton" text="Refresh" onAction="#onRefreshDevices"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="startStopButton" styleClass="btn-primary" onAction="#onStartStop"/>
    </HBox>

    <VBox spacing="10.0" alignment="CENTER" styleClass="card">
        <Canvas fx:id="previewCanvas" width="560.0" height="420.0"/>
        <Label fx:id="heartRateLabel" styleClass="hr-readout"/>
        <Label fx:id="statusLabel" wrapText="true" styleClass="status"/>
    </VBox>

    <VBox spacing="6.0" styleClass="card">
        <Label text="HEART-RATE TREND (BPM)" styleClass="section-label"/>
        <Canvas fx:id="trendCanvas" width="560.0" height="90.0"/>
    </VBox>

    <Label text="Estimate only, not medical-grade" styleClass="disclaimer"/>
</VBox>
