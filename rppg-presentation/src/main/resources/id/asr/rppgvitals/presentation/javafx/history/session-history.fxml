<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="id.asr.rppgvitals.presentation.javafx.history.SessionHistoryController"
      spacing="14.0" alignment="TOP_CENTER">
    <padding>
        <Insets top="18.0" right="20.0" bottom="16.0" left="20.0"/>
    </padding>

    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <Button fx:id="backButton" text="◂ Back" onAction="#onBack"/>
        <VBox spacing="1.0">
            <Label text="Session History" styleClass="h1"/>
            <Label text="Your saved measurements" styleClass="subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="deleteButton" text="Delete" styleClass="btn-danger" onAction="#onDelete"/>
    </HBox>

    <VBox spacing="8.0" alignment="CENTER" styleClass="card" VBox.vgrow="ALWAYS">
        <TableView fx:id="sessionsTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="dateColumn" text="Date &amp; time" prefWidth="190.0"/>
                <TableColumn fx:id="durationColumn" text="Duration" prefWidth="95.0"/>
                <TableColumn fx:id="heartRateColumn" text="Mean HR" prefWidth="115.0"/>
                <TableColumn fx:id="confidenceColumn" text="Confidence" prefWidth="105.0"/>
            </columns>
        </TableView>
        <Label fx:id="emptyLabel" text="No sessions recorded yet" styleClass="subtitle"/>
    </VBox>

    <Label text="Estimate only, not medical-grade" styleClass="disclaimer"/>
</VBox>
